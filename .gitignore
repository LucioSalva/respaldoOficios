# Variables de entorno (NUNCA commitear)
.env

# Uploads de usuarios
uploads/*
!uploads/.gitkeep

# Docker volumes
pgdata/

# Logs
*.log

# Temporales
*.tmp
*.swp
~$*

# Python
__pycache__/
*.pyc
.venv/

# Configuraciones locales de Claude Code
.claude/settings.local.json

# Paquetes de distribucion y dumps de DB (no versionar binarios grandes ni datos reales)
*.zip
*.rar
*.7z
respaldoOficios_PRODUCCION.zip
respaldooficios.sql
paquete_produccion/

# Archivos fuente originales del cliente (Excel con datos)
*.xlsx
*.xls

