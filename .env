# =============================================================================
# RESPALDO DE OFICIOS - Variables de Entorno (Laragon - Produccion local)
# Modo de despliegue: subcarpeta /oficios bajo Apache existente, puerto 8080.
# La app convive con otras aplicaciones en el mismo servidor.
# =============================================================================

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=respaldooficios
DB_USER=postgres
# AJUSTE MANUAL: si la clave real de PostgreSQL en el servidor difiere, editar aqui.
DB_PASS=admin

APP_ENV=production
APP_DEBUG=false

# APP_URL NO debe incluir /oficios. La ruta base se compone con APP_BASE_PATH.
APP_URL=http://187.174.221.162:8080
APP_BASE_PATH=/oficios

APP_SECRET=r3sp4ld0_0f1c10s_s3cr3t_k3y_2026_v1_produccion_interna_ayuntamiento

SESSION_LIFETIME=7200
SESSION_NAME=respaldo_oficios_sess

CSRF_TOKEN_NAME=csrf_token

UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=C:/laragon/www/oficios/uploads

APP_TIMEZONE=America/Mexico_City
