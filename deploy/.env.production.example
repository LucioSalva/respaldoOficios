# =============================================================================
# RESPALDO DE OFICIOS - Variables de Entorno (Produccion / Laragon)
# Copiar este archivo a la RAIZ del proyecto como .env
#   Ruta final: C:\laragon\www\respaldoOficios\.env
# =============================================================================

# --- Base de datos PostgreSQL (PostgreSQL instalado en Laragon o standalone) ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=respaldooficios
DB_USER=postgres
DB_PASS=CAMBIAR_ESTA_CLAVE_EN_PRODUCCION

# --- Aplicacion ---
APP_ENV=production
APP_DEBUG=false
APP_URL=http://respaldo-oficios.test:8080
APP_SECRET=GENERAR_CADENA_ALEATORIA_DE_64_CARACTERES_MINIMO_EN_PRODUCCION_AQUI

# --- Sesion ---
SESSION_LIFETIME=7200
SESSION_NAME=respaldo_oficios_sess

# --- Uploads (ruta Windows absoluta - Laragon) ---
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=C:/laragon/www/respaldoOficios/uploads

# --- Zona horaria ---
APP_TIMEZONE=America/Mexico_City
