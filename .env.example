# =============================================================================
# RESPALDO DE OFICIOS - Variables de Entorno
# Copiar este archivo como .env y ajustar valores
# =============================================================================

# Base de datos PostgreSQL
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=respaldooficios
DB_USER=postgres
DB_PASS=CambiarEstoEnProduccion2026!

# Configuración de la aplicación
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8090
APP_SECRET=cambiar_por_cadena_aleatoria_de_64_caracteres_minimo_aqui_2026

# Sesiones
SESSION_LIFETIME=7200
SESSION_NAME=respaldo_oficios_sess

# Uploads
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=/var/www/uploads

# Zona horaria
APP_TIMEZONE=America/Mexico_City
