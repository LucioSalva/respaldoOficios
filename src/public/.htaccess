Options -Indexes

RewriteEngine On

# No reescribir archivos/directorios existentes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Todo va al front controller
RewriteRule ^(.*)$ index.php [QSA,L]

# Deshabilitar acceso a archivos sensibles por extensión
<FilesMatch "\.(env|sql|log|sh|md|yml|yaml|json|ini|bak|swp|git)$">
    Require all denied
</FilesMatch>

# Bloquear TODOS los .php directos por defecto
<FilesMatch "\.php$">
    Require all denied
</FilesMatch>

# Única excepción: el front controller
<Files "index.php">
    Require all granted
</Files>
